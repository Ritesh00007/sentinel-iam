# Sentinel-IAM Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Required: GitHub Personal Access Token
# Scopes needed: read:org, read:user, repo
GITHUB_TOKEN=your_github_token_here

# Optional: Default organization (can also pass via --org flag)
GITHUB_ORG=your-org-name

# Optional: Dashboard port (default: 4567)
DASHBOARD_PORT=4567
